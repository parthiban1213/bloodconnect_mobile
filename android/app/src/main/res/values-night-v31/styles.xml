<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Android 12+ dark-mode: override splash to plain white, no icon.
      Without this, dark-mode devices on API 31+ fall through to the default
      app icon splash because values-night/styles.xml has no v31 override.
    -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_blank</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_blank</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
    </style>
</resources>
